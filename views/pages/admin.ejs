<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('../partials/head') %>
    <link rel="stylesheet" href="/style/page/admin.css">
    <title>Админ панель - BilimAll</title>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="admin-container">
        <div class="admin-header">
            <h1>🛠️ Панель администратора</h1>
            <span>Добро пожаловать, <%= user.name %>!</span>
        </div>

        <div id="loading" class="loading">
            Загрузка данных...
        </div>

        <div id="admin-content" style="display: none;">
            <div class="admin-stats">
                <div class="stat-card">
                    <div class="stat-icon">📚</div>
                    <div class="stat-value" id="themes-count">0</div>
                    <div class="stat-label">Тем курсов</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📖</div>
                    <div class="stat-value" id="lectures-count">0</div>
                    <div class="stat-label">Лекций</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📝</div>
                    <div class="stat-value" id="tests-count">0</div>
                    <div class="stat-label">Тестов</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">👥</div>
                    <div class="stat-value" id="users-count">0</div>
                    <div class="stat-label">Пользователей</div>
                </div>
            </div>

            <div class="admin-sections">
                <div class="admin-section">
                    <div class="section-header">
                        <h2 class="section-title">Темы курсов</h2>
                        <button class="add-button" onclick="openThemeModal()">
                            ➕ Добавить тему
                        </button>
                    </div>
                    <div id="themes-list" class="items-list">
                        <!-- Темы загружаются через JS -->
                    </div>
                </div>

                <div class="admin-section">
                    <div class="section-header">
                        <h2 class="section-title">Лекции</h2>
                        <button class="add-button" onclick="openLectureModal()">
                            ➕ Добавить лекцию
                        </button>
                    </div>
                    <div id="lectures-list" class="items-list">
                        <!-- Лекции загружаются через JS -->
                    </div>
                </div>

                <div class="admin-section">
                    <div class="section-header">
                        <h2 class="section-title">Тесты</h2>
                        <button class="add-button" onclick="openTestModal()">
                            ➕ Добавить тест
                        </button>
                    </div>
                    <div id="tests-list" class="items-list">
                        <!-- Тесты загружаются через JS -->
                    </div>
                </div>

                <div class="admin-section">
                    <div class="section-header">
                        <h2 class="section-title">Пользователи</h2>
                    </div>
                    <div id="users-list" class="items-list">
                        <!-- Пользователи загружаются через JS -->
                    </div>
                </div>

                <div class="admin-section">
                    <div class="section-header">
                        <h2 class="section-title">Галерея</h2>
                    </div>
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <input type="text" id="gallery-title" placeholder="Название (необязательно)" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px; margin-bottom: 0.75rem;">
                        <input type="file" id="gallery-file" accept="image/*,video/*" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px; margin-bottom: 0.75rem;">
                        <button class="add-button" type="button" onclick="uploadGalleryMedia()">⬆️ Загрузить в галерею</button>
                    </div>
                    <div id="gallery-list" class="items-list">
                        <!-- Галерея загружается через JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для темы -->
    <div id="theme-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="theme-modal-title">Добавить тему</h3>
                <button class="close-button" onclick="closeThemeModal()">✕</button>
            </div>
            <form id="theme-form">
                <input type="hidden" id="theme-id">
                <div class="form-group">
                    <label for="theme-title">Название темы *</label>
                    <input type="text" id="theme-title" required>
                </div>
                <div class="form-group">
                    <label for="theme-description">Описание</label>
                    <textarea id="theme-description"></textarea>
                </div>
                <div class="form-group">
                    <label for="theme-image">Изображение темы</label>
                    <input type="file" id="theme-image-file" accept="image/*" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                    <small style="color: #7f8c8d; display: block; margin-top: 0.5rem;">Загрузите изображение (jpg, png, gif, webp). Макс: 5MB</small>
                    <div id="image-preview" style="margin-top: 1rem; display: none;">
                        <img id="image-preview-img" src="" alt="Предпросмотр" style="width: 100%; max-height: 200px; object-fit: cover; border-radius: 6px;">
                    </div>
                    <input type="hidden" id="theme-image">
                </div>
                <div class="form-group">
                    <label for="theme-order">Порядок</label>
                    <input type="number" id="theme-order" value="0">
                </div>
                <button type="submit" class="submit-button">Сохранить</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно для лекции -->
    <div id="lecture-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="lecture-modal-title">Добавить лекцию</h3>
                <button class="close-button" onclick="closeLectureModal()">✕</button>
            </div>
            <form id="lecture-form">
                <input type="hidden" id="lecture-id">
                <div class="form-group">
                    <label for="lecture-theme">Выберите тему *</label>
                    <select id="lecture-theme" required style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                        <option value="">-- Выберите тему --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="lecture-title">Название лекции *</label>
                    <input type="text" id="lecture-title" required>
                </div>
                <div class="form-group">
                    <label for="lecture-content">Содержание (Markdown) *</label>
                    <textarea id="lecture-content" required style="min-height: 250px;"></textarea>
                </div>
                <div class="form-group">
                    <label for="lecture-images-files">Фотографии для лекции</label>
                    <input type="file" id="lecture-images-files" accept="image/*" multiple style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                    <small style="color: #7f8c8d; display: block; margin-top: 0.5rem;">Можно выбрать несколько фото. Они загрузятся и автоматически добавятся в Markdown контент лекции.</small>
                    <div id="lecture-images-preview" style="margin-top: 1rem; display: none; gap: 0.75rem; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));"></div>
                </div>
                <div class="form-group">
                    <label for="lecture-video">Видео или PDF файл</label>
                    <input type="file" id="lecture-video-file" accept="video/*,.pdf,application/pdf" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                    <small style="color: #7f8c8d; display: block; margin-top: 0.5rem;">Загрузите видео (mp4, avi, mkv, mov, webm) или PDF. Макс: видео 100MB, PDF 20MB</small>
                    <div id="video-preview" style="margin-top: 1rem; display: none;">
                        <video id="video-preview-player" controls style="width: 100%; max-height: 300px; border-radius: 6px;"></video>
                    </div>
                    <div id="pdf-preview" style="margin-top: 1rem; display: none;">
                        <iframe id="pdf-preview-frame" src="" style="width: 100%; min-height: 420px; border: 1px solid #ddd; border-radius: 6px;" title="PDF предпросмотр"></iframe>
                    </div>
                    <input type="hidden" id="lecture-video">
                </div>
                <div class="form-group">
                    <label for="lecture-duration">Длительность (мин)</label>
                    <input type="number" id="lecture-duration" value="15">
                </div>
                <div class="form-group">
                    <label for="lecture-order">Порядок</label>
                    <input type="number" id="lecture-order" value="0">
                </div>
                <button type="submit" class="submit-button">Сохранить</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно для теста -->
    <div id="test-modal" class="modal">
        <div class="modal-content" style="max-height: 90vh; overflow-y: auto;">
            <div class="modal-header" style="position: sticky; top: 0; background: white; z-index: 10;">
                <h3 class="modal-title" id="test-modal-title">Добавить тест</h3>
                <button class="close-button" onclick="closeTestModal()">✕</button>
            </div>
            <form id="test-form" style="padding: 2rem;">
                <input type="hidden" id="test-id">
                <div class="form-group">
                    <label for="test-lecture">Выберите лекцию *</label>
                    <select id="test-lecture" required style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                        <option value="">-- Выберите лекцию --</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="test-title">Название теста *</label>
                    <input type="text" id="test-title" required>
                </div>
                <div class="form-group">
                    <label for="test-number">Номер теста (1 или 2) *</label>
                    <select id="test-number" required style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 6px;">
                        <option value="1">Тест 1 (основной)</option>
                        <option value="2">Тест 2 (переэкзамен)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="test-passing-score">Минимальный балл для прохождения (%) *</label>
                    <input type="number" id="test-passing-score" min="0" max="100" value="70" required>
                </div>
                <div class="form-group">
                    <label for="test-time-limit">Время на тест (мин)</label>
                    <input type="number" id="test-time-limit" min="1" value="30">
                </div>

                <hr style="margin: 2rem 0;">
                <h4 style="margin-bottom: 1rem;">Вопросы</h4>
                <div id="questions-container" style="margin-bottom: 1rem;"></div>
                <button type="button" class="add-button" onclick="addQuestion()">➕ Добавить вопрос</button>

                <hr style="margin: 2rem 0;">
                <button type="submit" class="submit-button">Сохранить тест</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="/js/admin.js"></script>
</body>
</html>
