<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head.ejs') %>
    <title>Document</title>
</head>
<body class="body_login">
    <div class="form"> 
        <div class="user_login">
            <img src="/images/icons/user.png" alt="">
        </div>
        <div class="form_action">
            <% if (error) { %>
                <div class="error-message" style="color: #ff4444; background: rgba(255, 68, 68, 0.1); padding: 10px; border-radius: 8px; margin-bottom: 15px; text-align: center;">
                    <%= error %>
                </div>
            <% } %>
            <form action="/register" method="post" data-validate>
                <fieldset>
                    <label for="name">Имя</label>
                    <input type="text" id="name" name="name" placeholder="Введите имя" required>
                </fieldset>
                <fieldset>
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="Введите email" required>
                </fieldset>
                <fieldset>
                    <label for="password">Пароль</label>
                    <input type="password" id="password" name="password" placeholder="Не менее 6 символов" required>
                </fieldset>
                <fieldset>
                    <label for="confirmPassword">Повторите пароль</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Повторите пароль" required>
                </fieldset>
                <button type="submit">Зарегистрироваться</button>
            </form>
            <p>У вас есть аккаунт? <a href="/login">Войдите</a></p>
        </div>
    </div>
    <script src="/js/main.js"></script>
</body>
</html>