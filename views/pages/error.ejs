<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('../partials/head') %>
    <title>Ошибка доступа - BilimHub</title>
    <style>
        .error-container {
            max-width: 480px;
            margin: 4rem auto;
            padding: 2.5rem;
            text-align: center;
            background: var(--color-surface);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            border: 1px solid var(--color-border);
        }
        .error-icon { font-size: 3.5rem; margin-bottom: 1rem; }
        .error-title { font-size: 1.5rem; color: var(--color-danger); margin-bottom: 0.75rem; font-weight: 700; }
        .error-message { font-size: 1rem; color: var(--color-text-muted); margin-bottom: 1.5rem; }
        .error-container .back-button {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            background: var(--color-primary);
            color: white;
            text-decoration: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 0.95rem;
            transition: background 0.2s;
        }
        .error-container .back-button:hover { background: var(--color-primary-hover); }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="error-container">
        <div class="error-icon">🚫</div>
        <h1 class="error-title">Доступ запрещен</h1>
        <p class="error-message">
            <%= message || 'У вас нет прав для доступа к этой странице' %>
        </p>
        <a href="/" class="back-button">← Вернуться на главную</a>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>
